// ==========================
// PERSON 1 FUNCTIONS
// ==========================

NodePtr getLane(NodePtr head, int index){
    int count = 0;

    while(head != NULL){
        if(count == index){
            return head;
        }

        head = head->next;
        count++;
    }

    return NULL;
}

void appendLane(NodePtr &head, string lane){
    NodePtr newNode = new Node;

    newNode->data = lane;
    newNode->next = NULL;

    if(head == NULL){
        head = newNode;
    }
    else{
        NodePtr temp = head;

        while(temp->next != NULL){
            temp = temp->next;
        }

        temp->next = newNode;
    }
}

NodePtr buildRoad(){
    NodePtr head = NULL;

    // Row 0 finish line
    appendLane(head, "|" + string(40, '=') + "|");

    // Rows 1-20
    for(int i = 1; i <= 20; i++){

        if(i == 6 || i == 9 || i == 15 || i == 18){
            appendLane(head, generateBufferLane());
        }
        else if(i == 7 || i == 8 || i == 16 || i == 17){
            appendLane(head, generateRiverLane());
        }
        else{
            appendLane(head, generateRoadLane());
        }
    }
    
    appendLane(head, "|" + string(40, '.') + "|");
    appendLane(head, "|" + string(40, '.') + "|");

    return head;
}

void freeList(NodePtr &head){
    NodePtr temp;

    while(head != NULL){
        temp = head;
        head = head->next;
        delete temp;
    }

    head = NULL;
}

