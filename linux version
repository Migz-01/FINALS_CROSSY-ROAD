void titleScreen();

string generateBufferLane(){
    return "|" + string(40, '.') + "|";
}

string generateRoadLane(){
    string lane = string(40, '.');

    // 3 trucks
    for(int t = 0; t < 3; t++){
        int pos = rand() % 35;

        for(int i = 0; i < 5; i++){
            lane[pos + i] = '#';
        }
    }

    return "|" + lane + "|";
}

string generateRiverLane(){
    string lane = string(40, '~');

    // 3 logs
    for(int t = 0; t < 3; t++){
        int pos = rand() % 36;

        for(int i = 0; i < 4; i++){
            lane[pos + i] = '=';
        }
    }

    return "|" + lane + "|";
}


