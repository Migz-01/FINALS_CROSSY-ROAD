// MAIN
// =====================================

int main()
{
    srand(time(0));
    
    hideCursor();

    showTitleScreen();

    string playerName = getPlayerName();

    int difficulty = chooseDifficulty();

    int gameSpeed;

    if (difficulty == 1)
    {
        gameSpeed = 180;
    }
    else
    {
        gameSpeed = 100;
    }

    NodePtr head = buildRoad(difficulty);

    int playerX = 20;
    int playerY = 19;

    int lives = 3;
    int crossings = 0;

    bool running = true;

    while (running)
    {
        // move obstacles
        shiftObstacles(head);

        // move player with logs
        updatePlayerWithLog(head,
                            playerX,
                            playerY);

        // input
        keyboardInput(playerX,
                      playerY);

        // collision
        if (checkCollision(head,
                           playerX,
                           playerY))
        {
            lives--;

            playerX = 20;
            playerY = 19;

            Sleep(500);
        }

        // drowning
        if (checkDrowned(head,
                         playerX,
                         playerY))
        {
            lives--;

            playerX = 20;
            playerY = 19;

            Sleep(500);
        }

        // WIN CROSSING
        if (playerY == 0)
        {
            crossings++;

            playerX = 20;
            playerY = 19;

            freeList(head);

            head = buildRoad(difficulty);

            Sleep(500);
        }

        // FULL GAME WIN
        if (crossings == 5)
        {
            system("cls");

            cout << "====================================\n";
            cout << " YOU WIN!\n";
            cout << "====================================\n\n";

            cout << playerName
                 << " completed 5 crossings!\n";

            saveScore(playerName, crossings);

            showLeaderboard();

            running = false;
        }

        // GAME OVER
        if (lives <= 0)
        {
            system("cls");

            cout << "====================================\n";
            cout << " GAME OVER\n";
            cout << "====================================\n\n";

            cout << playerName
                 << " lost all lives!\n";

            running = false;
        }

        displayRoad(head,
                    playerX,
                    playerY,
                    playerName,
                    lives,
                    crossings);

        Sleep(gameSpeed);
    }

    freeList(head);

    return 0;
}
