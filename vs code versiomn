void appendNode(NodePtr& head, string lane)
{
    NodePtr newNode = new Node;

    newNode->data = lane;
    newNode->next = NULL;

    if (head == NULL)
    {
        head = newNode;
    }
    else
    {
        NodePtr temp = head;

        while (temp->next != NULL)
        {
            temp = temp->next;
        }

        temp->next = newNode;
    }
}

NodePtr getLane(NodePtr head, int index)
{
    NodePtr temp = head;

    int counter = 0;

    while (temp != NULL && counter < index)
    {
        temp = temp->next;
        counter++;
    }

    return temp;
}

void freeList(NodePtr& head)
{
    NodePtr temp;

    while (head != NULL)
    {
        temp = head;
        head = head->next;

        delete temp;
    }

    head = NULL;
}

string shiftLeft(string lane)
{
    string inner = lane.substr(1, WIDTH);

    char first = inner[0];

    for (int i = 0; i < WIDTH - 1; i++)
    {
        inner[i] = inner[i + 1];
    }

    inner[WIDTH - 1] = first;

    return "|" + inner + "|";
}

string shiftRight(string lane)
{
    string inner = lane.substr(1, WIDTH);

    char last = inner[WIDTH - 1];

    for (int i = WIDTH - 1; i > 0; i--)
    {
        inner[i] = inner[i - 1];
    }

    inner[0] = last;

    return "|" + inner + "|";
}

string generateBufferLane()
{
    string lane = "|";

    for (int i = 0; i < WIDTH; i++)
    {
        lane += '.';
    }

    lane += "|";

    return lane;
}

string generateRoadLane(int laneNum, int difficulty)
{
    string lane(WIDTH, '.');

    int trucks;

    if (difficulty == 1)
    {
        trucks = 2;
    }
    else
    {
        trucks = 3;
    }

    for (int t = 0; t < trucks; t++)
    {
        int start = rand() % (WIDTH - 5);

        for (int i = 0; i < 5; i++)
        {
            lane[start + i] = '#';
        }
    }

    return "|" + lane + "|";
}

string generateRiverLane(int laneNum, int difficulty)
{
    string lane(WIDTH, '~');

    int logs;

    if (difficulty == 1)
    {
        logs = 2;
    }
    else
    {
        logs = 3;
    }

    for (int l = 0; l < logs; l++)
    {
        int start = rand() % (WIDTH - 4);

        for (int i = 0; i < 4; i++)
        {
            lane[start + i] = '=';
        }
    }

    return "|" + lane + "|";
}

NodePtr buildRoad(int difficulty)
{
    NodePtr head = NULL;

    // FINISH LINE
    appendNode(head, "|========================================|");

    // ROWS 1-5 ROAD
    for (int i = 0; i < 5; i++)
    {
        appendNode(head, generateRoadLane(i, difficulty));
    }

    // ROW 6 BUFFER
    appendNode(head, generateBufferLane());

    // ROWS 7-8 RIVER
    for (int i = 0; i < 2; i++)
    {
        appendNode(head, generateRiverLane(i, difficulty));
    }

    // ROW 9 BUFFER
    appendNode(head, generateBufferLane());

    // ROWS 10-14 ROAD
    for (int i = 0; i < 5; i++)
    {
        appendNode(head, generateRoadLane(i, difficulty));
    }

    // ROW 15 BUFFER
    appendNode(head, generateBufferLane());

    // ROWS 16-17 RIVER
    for (int i = 0; i < 2; i++)
    {
        appendNode(head, generateRiverLane(i, difficulty));
    }

    // ROW 18 BUFFER
    appendNode(head, generateBufferLane());

    // ROW 19 PLAYER START
    appendNode(head,
        "|........................................|");

    return head;
}

bool isRoadLane(int row)
{
    return (row >= 1 && row <= 5) ||
           (row >= 10 && row <= 14);
}

bool isRiverLane(int row)
{
    return (row >= 7 && row <= 8) ||
           (row >= 16 && row <= 17);
}

void displayRoad(NodePtr head,
                 int playerX,
                 int playerY,
                 string playerName,
                 int lives,
                 int crossings)
{
    gotoXY(0, 0);

    setColor(11);

    cout << "---------- Road Crossing Challenge ----------\n";

    setColor(15);

    cout << "Player: "
         << playerName
         << " | Lives: "
         << lives
         << " | Crossings: "
         << crossings
         << "          \n";

    NodePtr temp = head;

    int row = 0;

    while (temp != NULL)
    {
        string lane = temp->data;

        // overlay player
        if (row == playerY)
        {
            lane[playerX] = PLAYER;
        }

        for (int i = 0; i < lane.length(); i++)
        {
            char c = lane[i];

            // trucks
            if (c == '#')
            {
                setColor(12);
            }

            // logs + finish
            else if (c == '=')
            {
                setColor(6);
            }

            // water
            else if (c == '~')
            {
                setColor(9);
            }

            // player
            else if (c == 'P')
            {
                setColor(10);
            }

            // borders
            else if (c == '|')
            {
                setColor(15);
            }

            // safe lane
            else
            {
                setColor(8);
            }

            cout << c;
        }

        cout << "   \n";

        temp = temp->next;
        row++;
    }

    setColor(15);

    cout << "\nArrow Keys to Move        \n";
}   

void shiftObstacles(NodePtr head)
{
    NodePtr temp = head;

    int row = 0;

    while (temp != NULL)
    {
        if (isRoadLane(row))
        {
            // alternating directions
            if (row % 2 == 1)
            {
                temp->data = shiftRight(temp->data);
            }
            else
            {
                temp->data = shiftLeft(temp->data);
            }
        }

        else if (isRiverLane(row))
        {
            if (row % 2 == 1)
            {
                temp->data = shiftRight(temp->data);
            }
            else
            {
                temp->data = shiftLeft(temp->data);
            }
        }

        temp = temp->next;
        row++;
    }
}

bool checkCollision(NodePtr head,
                    int playerX,
                    int playerY)
{
    if (!isRoadLane(playerY))
    {
        return false;
    }

    NodePtr lane = getLane(head, playerY);

    if (lane == NULL)
    {
        return false;
    }

    if (lane->data[playerX] == '#')
    {
        return true;
    }

    return false;
}

bool checkDrowned(NodePtr head,
                  int playerX,
                  int playerY)
{
    if (!isRiverLane(playerY))
    {
        return false;
    }

    NodePtr lane = getLane(head, playerY);

    if (lane == NULL)
    {
        return false;
    }

    if (lane->data[playerX] == '~')
    {
        return true;
    }

    return false;
}

void updatePlayerWithLog(NodePtr head,
                         int& playerX,
                         int playerY)
{
    if (!isRiverLane(playerY))
    {
        return;
    }

    NodePtr lane = getLane(head, playerY);

    if (lane == NULL)
    {
        return;
    }

    // player standing on log
    if (lane->data[playerX] == '=')
    {
        // odd rows move right
        if (playerY % 2 == 1)
        {
            playerX++;
        }
        else
        {
            playerX--;
        }

        // boundary death
        if (playerX <= 0 || playerX >= 41)
        {
            playerX = 20;
        }
    }
}

void keyboardInput(int& playerX,
                   int& playerY)
{
    if (_kbhit())
    {
        int key = _getch();

        // arrow keys
        if (key == 224)
        {
            key = _getch();

            switch (key)
            {
                case 72: // UP
                    if (playerY > 0)
                    {
                        playerY--;
                    }
                    break;

                case 80: // DOWN
                    if (playerY < 19)
                    {
                        playerY++;
                    }
                    break;

                case 75: // LEFT
                    if (playerX > 1)
                    {
                        playerX--;
                    }
                    break;

                case 77: // RIGHT
                    if (playerX < 40)
                    {
                        playerX++;
                    }
                    break;
            }
        }
    }
}

void hideCursor()
{
    HANDLE consoleHandle =
        GetStdHandle(STD_OUTPUT_HANDLE);

    CONSOLE_CURSOR_INFO info;

    info.dwSize = 100;
    info.bVisible = FALSE;

    SetConsoleCursorInfo(consoleHandle, &info);
}

void gotoXY(int x, int y)
{
    COORD coord;

    coord.X = x;
    coord.Y = y;

    SetConsoleCursorPosition(
        GetStdHandle(STD_OUTPUT_HANDLE),
        coord
    );
}

