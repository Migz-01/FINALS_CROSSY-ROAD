void showLeaderboard()
{
    ifstream file("leaderboard.txt");

    vector<LeaderboardEntry> entries;

    LeaderboardEntry temp;

    while (file >> temp.name >> temp.score)
    {
        entries.push_back(temp);
    }

    file.close();

    sort(entries.begin(),
         entries.end(),
         [](LeaderboardEntry a,
            LeaderboardEntry b)
         {
             return a.score > b.score;
         });

    cout << "\n===== LEADERBOARD =====\n\n";

    int limit;

    if (entries.size() < 5)
    {
        limit = entries.size();
    }
    else
    {
        limit = 5;
    }

    for (int i = 0; i < limit; i++)
    {
        cout << i + 1
             << ". "
             << entries[i].name
             << " - "
             << entries[i].score
             << " crossing(s)\n";
    }

    cout << endl;
}

